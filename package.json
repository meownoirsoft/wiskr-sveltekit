{
	"name": "wiskr-sveltekit",
	"private": true,
	"version": "1.0.0",
	"description": "A modern, responsive web application for managing AI prompts and conversations across multiple AI models. Built with SvelteKit.",
	"type": "module",
	"scripts": {
		"dev": "NODE_ENV=development vite dev",
    	"dev:fast": "NODE_ENV=development vite dev --force",
		"admin": "vite dev --config vite.admin.config.js --port 5174",
		"dev:both": "concurrently \"pnpm run dev\" \"pnpm run dev:admin\"",
		"build": "vite build",
		"build:admin": "vite build --config vite.admin.config.js",
		"build:both": "pnpm run build && pnpm run build:admin",
		"preview": "vite preview",
		"preview:admin": "vite preview --config vite.admin.config.js --port 5175",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json --watch",
		"check:fast": "svelte-check --tsconfig ./jsconfig.json",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"analyze": "vite-bundle-analyzer dist",
		"clean": "rm -rf .svelte-kit node_modules/.vite",
		"fresh": "pnpm run clean && pnpm install && pnpm run dev"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^6.0.0",
		"@sveltejs/kit": "^2.22.0",
		"@sveltejs/vite-plugin-svelte": "^6.0.0",
		"@tailwindcss/forms": "^0.5.10",
		"@tailwindcss/postcss": "^4.1.11",
		"@tailwindcss/typography": "^0.5.16",
		"@tailwindcss/vite": "^4.0.0",
		"@types/node": "^22",
		"autoprefixer": "^10.4.21",
		"concurrently": "^8.2.2",
		"drizzle-kit": "^0.30.2",
		"mdsvex": "^0.12.3",
		"postcss": "^8.5.6",
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.0",
		"tailwindcss": "^4.1.11",
		"typescript": "^5.0.0",
		"vite": "^7.0.4"
	},
	"dependencies": {
		"@floating-ui/dom": "^1.7.3",
		"@supabase/auth-helpers-sveltekit": "^0.13.0",
		"@supabase/ssr": "^0.6.1",
		"@supabase/supabase-js": "^2.54.0",
		"drizzle-orm": "^0.40.0",
		"jszip": "^3.10.1",
		"lodash-es": "^4.17.21",
		"lucide-svelte": "^0.539.0",
		"luxon": "^3.7.1",
		"marked": "^16.1.2",
		"openai": "^5.12.2",
		"postgres": "^3.4.5",
		"posthog-js": "^1.260.1"
	}
}
