{
  "name": "wiskr-sveltekit",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "dev": "vite dev",
    "dev:fast": "phase run --env development 'NODE_ENV=development vite dev --force'",
    "dev:hmr": "phase run --env development 'NODE_ENV=development vite dev --port 5173 --force --host'",
    "dev:admin": "vite dev --config vite.admin.config.js --port 5174",
    "dev:both": "concurrently \"pnpm run dev\" \"pnpm run dev:admin\"",
    "build": "svelte-kit sync && vite build",
    "build:admin": "vite build --config vite.admin.config.js",
    "build:both": "pnpm run build && pnpm run build:admin",
    "increment-build": "node scripts/increment-build.js",
    "build:increment": "pnpm run increment-build && pnpm run build",
    "preview": "vite preview",
    "preview:admin": "vite preview --config vite.admin.config.js --port 5175",
    "start": "node build",
    "check": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json --watch",
    "clean": "rm -rf .svelte-kit node_modules/.vite",
    "fresh": "pnpm run clean && pnpm install && pnpm run dev"
  },
  "devDependencies": {
    "@sveltejs/adapter-netlify": "^5.2.3",
    "@sveltejs/adapter-node": "^5.3.1",
    "@sveltejs/kit": "^2.22.0",
    "@sveltejs/vite-plugin-svelte": "^6.0.0",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/postcss": "^4.1.11",
    "@tailwindcss/typography": "^0.5.16",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22",
    "autoprefixer": "^10.4.21",
    "concurrently": "^8.2.2",
    "postcss": "^8.5.6",
    "puppeteer": "^24.17.1",
    "rollup-plugin-visualizer": "^6.0.3",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4.1.11",
    "typescript": "^5.0.0",
    "vite": "^7.0.4"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.3",
    "@sentry/sveltekit": "^10",
    "@supabase/auth-helpers-sveltekit": "^0.13.0",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.54.0",
    "docx": "^9.5.1",
    "jszip": "^3.10.1",
    "lodash-es": "^4.17.21",
    "lucide-svelte": "^0.539.0",
    "luxon": "^3.7.1",
    "marked": "^16.1.2",
    "openai": "^5.12.2",
    "postgres": "^3.4.5",
    "posthog-js": "^1.260.1",
    "stripe": "^18.5.0"
  }
}
